---
import Layout from '../layouts/Layout.astro';

const stats = [
  { value: "10+", label: "Years Experience" },
  { value: "99.9%", label: "Uptime Secured" },
  { value: "24/7", label: "SOC Monitoring" }
];

const values = [
  {
    title: "Excellence",
    description: "We strive for the highest standards in everything we do.",
    icon: "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
  },
  {
    title: "Integrity",
    description: "Trust is earned through transparency and honest communication.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
  },
  {
    title: "Innovation",
    description: "We stay ahead of threats with cutting-edge technology and techniques.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  }
];
---

<Layout title="About">
  <section class="pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Hero -->
      <div class="text-center mb-20">
        <h1 class="font-heading font-bold text-5xl mb-6">About OneCyberLogix</h1>
        <p class="text-muted text-xl max-w-2xl mx-auto">We are a team of cybersecurity experts dedicated to protecting businesses from evolving digital threats.</p>
      </div>
      
      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20">
        {stats.map((stat) => (
          <div class="text-center p-6 rounded-2xl bg-surface border border-border">
            <div class="font-heading font-bold text-4xl text-primary mb-2">{stat.value}</div>
            <div class="text-muted">{stat.label}</div>
          </div>
        ))}
      </div>
      
      <!-- Mission -->
      <div class="grid md:grid-cols-2 gap-12 items-center mb-20">
        <div>
          <h2 class="font-heading font-bold text-3xl mb-6">Our Mission</h2>
          <p class="text-muted text-lg mb-6">
            At OneCyberLogix, we believe that every business deserves enterprise-grade cybersecurity. Our mission is to make advanced security accessible, understandable, and effective for organizations of all sizes.
          </p>
          <p class="text-muted text-lg">
            Founded with a vision to "Securing Tomorrow, Today," we combine cutting-edge technology with deep expertise to deliver comprehensive protection against modern cyber threats.
          </p>
        </div>
        <div class="p-8 rounded-2xl bg-surface border border-border">
          <h3 class="font-heading font-semibold text-xl mb-4">Why Choose Us?</h3>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-muted">Agentic IAM approach for smarter protection</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-muted">24/7 SOC monitoring</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-muted">Certified security experts</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-primary shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-muted">Customized security strategies</span>
            </li>
          </ul>
        </div>
      </div>
      
      <!-- Values -->
      <div>
        <h2 class="font-heading font-bold text-3xl text-center mb-12">Our Values</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {values.map((value) => (
            <div class="p-8 rounded-2xl bg-surface border border-border text-center">
              <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-6">
                <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={value.icon}/>
                </svg>
              </div>
              <h3 class="font-heading font-semibold text-xl mb-3">{value.title}</h3>
              <p class="text-muted">{value.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
