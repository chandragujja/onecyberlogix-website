---
import Layout from '../layouts/Layout.astro';

const businessPhone = import.meta.env.PUBLIC_BUSINESS_PHONE || '';
const businessEmail = import.meta.env.PUBLIC_BUSINESS_EMAIL || '';
---

<Layout title="Contact">
  <section class="pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h1 class="font-heading font-bold text-5xl mb-6">Contact Us</h1>
        <p class="text-muted text-xl max-w-2xl mx-auto">Ready to secure your business? Let's start a conversation.</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="p-8 rounded-2xl bg-surface border border-border">
          <h2 class="font-heading font-semibold text-2xl mb-6">Send us a Message</h2>
          <form class="space-y-6">
            <div>
              <label class="block text-sm font-medium mb-2">Name</label>
              <input type="text" class="w-full px-4 py-3 rounded-lg bg-background border border-border focus:border-primary focus:outline-none transition-colors" placeholder="Your name" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-2">Email</label>
              <input type="email" class="w-full px-4 py-3 rounded-lg bg-background border border-border focus:border-primary focus:outline-none transition-colors" placeholder="you@company.com" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-2">Company</label>
              <input type="text" class="w-full px-4 py-3 rounded-lg bg-background border border-border focus:border-primary focus:outline-none transition-colors" placeholder="Your company" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-2">Message</label>
              <textarea rows="5" class="w-full px-4 py-3 rounded-lg bg-background border border-border focus:border-primary focus:outline-none transition-colors" placeholder="Tell us about your security needs..."></textarea>
            </div>
            <button type="submit" class="w-full bg-primary text-background py-4 rounded-lg font-semibold hover:shadow-[0_0_20px_rgba(0,212,255,0.4)] transition-all">
              Send Message
            </button>
          </form>
        </div>
        
        <!-- Contact Info -->
        <div>
          <div class="mb-8">
            <h2 class="font-heading font-semibold text-2xl mb-6">Get in Touch</h2>
            <p class="text-muted mb-8">
              Have questions about our services? Want to discuss your security needs? Reach out and our team will get back to you within 24 hours.
            </p>
            
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-medium mb-1">Email</div>
                  {businessEmail && (
                    <a href={`mailto:${businessEmail}`} class="text-muted hover:text-primary transition">{businessEmail}</a>
                  )}
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-medium mb-1">Phone</div>
                  {businessPhone && (
                    <a href={`tel:${businessPhone.replace(/\D/g, '')}`} class="text-muted hover:text-primary transition">{businessPhone}</a>
                  )}
                </div>
              </div>
              
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="font-medium mb-1">Location</div>
                  <div class="text-muted">United States</div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Emergency Banner -->
          <div class="p-6 rounded-xl bg-secondary/10 border border-secondary/30">
            <div class="font-heading font-semibold text-lg mb-2">🚨 Security Emergency?</div>
            <p class="text-muted text-sm">
              If you're experiencing a security incident, call our emergency line:  24/7<span class="text-primary font-medium">{businessPhone || 'TBD'}</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

