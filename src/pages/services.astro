---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "Penetration Testing",
    description: "Comprehensive security assessments to identify vulnerabilities before attackers do.",
    features: ["Web Application Testing", "Network Penetration Testing", "Social Engineering", "API Security Testing"],
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
  },
  {
    title: "Security Operations Center",
    description: "24/7 monitoring and threat detection powered by advanced AI and expert analysts.",
    features: ["Real-time Monitoring", "Threat Detection", "Incident Response", "Log Management"],
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
  },
  {
    title: "Compliance & Risk Management",
    description: "Navigate complex regulatory requirements with expert guidance and proven frameworks.",
    features: ["SOC 2 Compliance", "ISO 27001", "HIPAA Compliance", "Risk Assessments"],
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
  },
  {
    title: "Incident Response",
    description: "Rapid deployment when security breaches occur. Minimize damage and recover fast.",
    features: ["24/7 Emergency Response", "Forensic Analysis", "Malware Removal", "Recovery Planning"],
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    title: "Cloud Security",
    description: "Secure your cloud infrastructure across AWS, Azure, and GCP environments.",
    features: ["Cloud Architecture Review", "Container Security", "IAM Configuration", "Cloud Compliance"],
    icon: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"
  },
  {
    title: "Security Training",
    description: "Empower your team with security awareness training and hands-on workshops.",
    features: ["Phishing Awareness", "Secure Coding", "Security Best Practices", "Custom Workshops"],
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
  }
];
---

<Layout title="Services">
  <section class="pt-32 pb-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h1 class="font-heading font-bold text-5xl mb-6">Our Services</h1>
        <p class="text-muted text-xl max-w-2xl mx-auto">Enterprise-grade cybersecurity solutions powered by advanced identity and access management.</p>
      </div>
      
      <div class="grid md:grid-cols-2 gap-8">
        {services.map((service, index) => (
          <div class="p-8 rounded-2xl bg-surface border border-border hover:border-primary/50 transition-all group">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform">
                <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.icon}/>
                </svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-xl mb-3">{service.title}</h3>
                <p class="text-muted mb-4">{service.description}</p>
                <ul class="space-y-2">
                  {service.features.map((feature) => (
                    <li class="flex items-center gap-2 text-sm text-muted">
                      <svg class="w-4 h-4 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                      </svg>
                      {feature}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <!-- Process Section -->
      <div class="mt-20">
        <h2 class="font-heading font-bold text-3xl text-center mb-12">How We Work</h2>
        <div class="grid md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-4 text-2xl font-bold text-primary">1</div>
            <h3 class="font-heading font-semibold mb-2">Assess</h3>
            <p class="text-muted text-sm">We analyze your security posture and identify vulnerabilities.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-4 text-2xl font-bold text-primary">2</div>
            <h3 class="font-heading font-semibold mb-2">Protect</h3>
            <p class="text-muted text-sm">Implement robust security measures and controls.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-4 text-2xl font-bold text-primary">3</div>
            <h3 class="font-heading font-semibold mb-2">Monitor</h3>
            <p class="text-muted text-sm">Continuous 24/7 monitoring for emerging threats.</p>
          </div>
          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-primary/20 flex items-center justify-center mx-auto mb-4 text-2xl font-bold text-primary">4</div>
            <h3 class="font-heading font-semibold mb-2">Respond</h3>
            <p class="text-muted text-sm">Rapid incident response when threats are detected.</p>
          </div>
        </div>
      </div>
      
      <!-- CTA -->
      <div class="mt-20 text-center">
        <a href="/contact" class="bg-primary text-background px-10 py-4 rounded-full font-semibold text-lg hover:shadow-[0_0_30px_rgba(0,212,255,0.4)] transition-all">
          Discuss Your Needs
        </a>
      </div>
    </div>
  </section>
</Layout>
