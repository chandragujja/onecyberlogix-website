---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="OneCyberLogix LLC - Agentic IAM Cybersecurity Services" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <title>{title} | OneCyberLogix</title>
  </head>
  <body class="bg-background text-gray-100 font-body">
    <nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-background/80 border-b border-border">
      <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
        <a href="/" class="font-heading font-bold text-2xl">
          <span class="text-primary">One</span><span class="text-white">Cyber</span><span class="text-secondary">Logix</span>
        </a>
        <div class="hidden md:flex gap-8">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <a href="/about" class="hover:text-primary transition-colors">About</a>
          <a href="/services" class="hover:text-primary transition-colors">Services</a>
          <a href="/contact" class="hover:text-primary transition-colors">Contact</a>
        </div>
        <a href="/contact" class="bg-primary text-background px-5 py-2 rounded-full font-semibold hover:shadow-[0_0_20px_rgba(0,212,255,0.4)] transition-all">
          Get Started
        </a>
      </div>
    </nav>
    
    <slot />
    
    <footer class="border-t border-border mt-20 py-12">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-4 gap-8">
          <div>
            <div class="font-heading font-bold text-xl mb-4">
              <span class="text-primary">One</span><span class="text-white">Cyber</span><span class="text-secondary">Logix</span>
            </div>
            <p class="text-muted text-sm">Securing Tomorrow, Today.</p>
          </div>
          <div>
            <h4 class="font-heading font-semibold mb-4">Services</h4>
            <ul class="space-y-2 text-muted text-sm">
              <li><a href="/services" class="hover:text-primary">Penetration Testing</a></li>
              <li><a href="/services" class="hover:text-primary">SOC</a></li>
              <li><a href="/services" class="hover:text-primary">Compliance</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-heading font-semibold mb-4">Company</h4>
            <ul class="space-y-2 text-muted text-sm">
              <li><a href="/about" class="hover:text-primary">About Us</a></li>
              <li><a href="/contact" class="hover:text-primary">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4 class="font-heading font-semibold mb-4">Contact</h4>
            <p class="text-muted text-sm">contact@onecyberlogix.com</p>
          </div>
        </div>
        <div class="border-t border-border mt-8 pt-8 text-center text-muted text-sm">
          © 2026 OneCyberLogix LLC. All rights reserved.
        </div>
      </div>
    </footer>
  </body>
</html>
